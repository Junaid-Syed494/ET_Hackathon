generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Article {
  id           String   @id @default(uuid())
  title        String
  summary      String
  link         String   @unique
  published_at DateTime
  topic_tag    String?
  created_at   DateTime @default(now())
}

// schema.prisma
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String    // Hashed for security
  persona       String?   // "investor", "founder", etc. (Null if they are new)
  isNewUser     Boolean   @default(true)
  interactions  Interaction[]
}

model Interaction {
  id          String   @id @default(cuid())
  userId      String
  articleId   String
  actionType  String   // "LIKE", "SHARE", or "READ"
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}