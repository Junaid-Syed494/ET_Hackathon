generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Article {
  id           String   @id @default(uuid())
  title        String
  summary      String
  link         String   @unique
  published_at DateTime
  topic_tag    String?
  created_at   DateTime @default(now())

  interactions Interaction[]
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  password        String    // Hashed
  selectedDomains String[]  @default([])
  isNewUser       Boolean   @default(true)
  
  // --- THE NEW SECURITY FIELDS ---
  emailVerified   DateTime? // If this is blank, they cannot log in
  verifyToken     String?   @unique // The secret code we send to their email
  
  interactions    Interaction[]
}

model Interaction {
  id          String   @id @default(cuid())
  userId      String
  articleId   String
  actionType  String   // "LIKE", "SHARE", or "READ"
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id])
  article     Article  @relation(fields: [articleId], references: [id])
}